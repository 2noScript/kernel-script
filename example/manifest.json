{
  "manifest_version": 3,
  "name": "Auto Script Extension",
  "version": "1.0.0",
  "description": "Chrome Extension built with React, TypeScript and Vite",

  "action": {

    "default_title": "Open Auto Script",
    "default_popup": "index.html"
  },
  "background": {
    "service_worker": "src/background.ts",
    "type": "module"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+S",
        "mac": "Command+Shift+S"
      },
      "description": "Open Auto Script popup"
    }
  },
  "permissions": [
    "storage",
    "alarms",
    "sidePanel",
    "activeTab",
    "scripting",
    "cookies"

  ],
  "host_permissions": [
    "<all_urls>"
  ]
}
