{
  "name": "kernel-script",
  "version": "1.0.5",
  "description": "Task queue manager for Chrome extensions with background processing, persistence, and React hooks",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    "types": "./dist/index.d.ts",
    "import": "./dist/index.js",
    "require": "./dist/index.cjs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/2noScript/kernel-script.git"
  },
  "homepage": "https://github.com/2noScript/kernel-script#readme",
  "bugs": {
    "url": "https://github.com/2noScript/kernel-script/issues"
  },
  "author": "2noScript <thangmk7@gmail.com>",
  "license": "MIT",
  "keywords": [
    "chrome-extension",
    "task-queue",
    "queue-manager",
    "automation",
    "script-runner",
    "background-tasks"
  ],
  "scripts": {
    "dev": "bun --watch run src/index.ts",
    "build": "tsc -p tsconfig.build.json && node esbuild.config.js && node scripts/fix-dts-paths.js",
    "lint": "eslint .",
    "format": "prettier --write .",
    "release": "bun run build && bunx bumpp --push",
    "prepublishOnly": "bun run build"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/chrome": "^0.1.40",
    "@types/react": "^19.2.14",
    "bumpp": "^10",
    "esbuild": "^0.28.0",
    "eslint": "^9",
    "globals": "^15",
    "prettier": "^3",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8"
  },
  "peerDependencies": {
    "react": "^19.2.5",
    "zustand": "^5.0.12"
  },
  "dependencies": {
    "idb-keyval": "^6.2.2",
    "p-queue": "^9.1.2"
  }
}
