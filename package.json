{
  "name": "ex-kernel-script",
  "version": "0.0.0",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    "types": "./dist/index.d.ts",
    "import": "./dist/index.js",
    "require": "./dist/index.cjs"
  },
  "scripts": {
    "dev": "bun --watch run src/index.ts",
    "build": "tsc -p tsconfig.build.json && node esbuild.config.js",
    "lint": "eslint .",
    "format": "prettier --write .",
    "release": "bun run build && bunx bumpp --push"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^19.2.14",
    "bumpp": "^10",
    "esbuild": "^0.28.0",
    "eslint": "^9",
    "globals": "^15",
    "prettier": "^3",
    "react": "^19.2.5",
    "typescript-eslint": "^8"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@types/chrome": "^0.1.40",
    "p-queue": "^9.1.2",
    "sonner": "^2.0.7",
    "zustand": "^5.0.12"
  }
}
